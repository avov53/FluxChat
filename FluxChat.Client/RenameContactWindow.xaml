<Window x:Class="FluxChat.Client.RenameContactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename contact"
        Width="520"
        Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        FontFamily="Segoe UI"
        Opacity="0"
        Loaded="Window_OnLoaded"
        KeyDown="Window_OnKeyDown"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#f2f3f5"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#b5bac1"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#80848e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#5865f2"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#4752c4"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="RoundedInput" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#383a40"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#4b4e57"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#363940"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#42454e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4a4d57"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDialogButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#66000000"
                CornerRadius="16"/>

        <Border x:Name="DialogCard"
                Width="480"
                MinHeight="336"
                Background="#2b2d31"
                BorderBrush="#45474f"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="10"
                                  Opacity="0.36"
                                  Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel>
                        <TextBlock Text="Rename friend"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="This changes only the local name in your friend list."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Width="34"
                            Height="34"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Close"
                            Click="CancelButton_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#484b54"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#5865f2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Stroke="#f2f3f5"
                              StrokeThickness="2.1"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M2,2 L13,13 M13,2 L2,13"
                              Width="15"
                              Height="15"
                              Stretch="Uniform"/>
                    </Button>
                </Grid>

                <Border Grid.Row="2"
                        Background="#24262c"
                        CornerRadius="12"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="46"
                              Height="46">
                            <Border CornerRadius="23"
                                    Background="#5865f2"/>
                            <Grid>
                                <Grid.Clip>
                                    <EllipseGeometry Center="23,23"
                                                     RadiusX="23"
                                                     RadiusY="23"/>
                                </Grid.Clip>
                                <Image x:Name="AvatarImage"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                                <MediaElement x:Name="AvatarVideo"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Stop"
                                              Stretch="UniformToFill"
                                              IsMuted="True"
                                              Visibility="Collapsed"
                                              MediaEnded="AvatarVideo_OnMediaEnded"/>
                            </Grid>
                            <TextBlock x:Name="InitialsText"
                                       Text="FC"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                        </Grid>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="CurrentNameText"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Friend display name"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="12"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="New name"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="2,0,0,7"/>
                    <TextBox x:Name="NameInput"
                             Style="{StaticResource RoundedInput}"/>
                    <TextBlock x:Name="ValidationText"
                               Text="Enter a friend name."
                               Visibility="Collapsed"
                               Foreground="#f87171"
                               FontSize="12"
                               Margin="2,7,0,0"/>
                </StackPanel>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Cancel"
                            Grid.Column="1"
                            Style="{StaticResource DialogButton}"
                            Click="CancelButton_OnClick"/>
                    <Button Content="Save changes"
                            Grid.Column="3"
                            Style="{StaticResource PrimaryDialogButton}"
                            MinWidth="126"
                            Click="SaveButton_OnClick"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
