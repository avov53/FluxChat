<Window x:Class="FluxChat.Client.RenameContactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename contact"
        Width="380"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#17191f"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="LineBrush" Color="#2a2f3a"/>
        <SolidColorBrush x:Key="TextBrush" Color="#eef2ff"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8f98ab"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#5eead4"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#12141a"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Rename contact" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="This changes only the local name in your contact list."
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <TextBox Grid.Row="2"
                 x:Name="NameInput"
                 VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Background="#242a35"
                    Foreground="{StaticResource TextBrush}"
                    Click="CancelButton_OnClick"/>
            <Button Content="Save"
                    Background="{StaticResource AccentBrush}"
                    Foreground="#061412"
                    Margin="10,0,0,0"
                    Click="SaveButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
