            <Border Grid.Row="0"
                    Height="58"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <Button DockPanel.Dock="Right"
                            Width="34"
                            Height="34"
                            Margin="10,0,0,0"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Settings"
                            VerticalAlignment="Center"
                            Click="SettingsButton_OnClick">
