                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.45"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ImageViewerToolbarButton}"
                                ToolTip="Close"
                                Click="ImageViewerCloseButton_OnClick">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="{StaticResource TextBrush}"
                                      Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z"/>
                            </Viewbox>
                        </Button>
                        <Button Margin="4,0,0,0"
                                Style="{StaticResource ImageViewerToolbarButton}"
                                ToolTip="Forward"
                                Click="ImageViewerForwardButton_OnClick">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="{StaticResource TextBrush}"
                                      Data="M14,9V5L21,12L14,19V14.9C9,14.9 5.5,16.5 3,20C4,15 7,10 14,9Z"/>
                            </Viewbox>
                        </Button>
                        <Button Margin="4,0,0,0"
                                Style="{StaticResource ImageViewerToolbarButton}"
                                ToolTip="Save image"
                                Click="ImageViewerSaveButton_OnClick">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="{StaticResource TextBrush}"
                                      Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"/>
                            </Viewbox>
                        </Button>
                        <Button Margin="4,0,0,0"
                                Style="{StaticResource ImageViewerToolbarButton}"
                                ToolTip="Copy image"
                                Click="ImageViewerCopyButton_OnClick">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="{StaticResource TextBrush}"
                                      Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="VideoViewerOverlay"
