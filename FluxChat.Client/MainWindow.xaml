                                            <TextBlock x:Name="GoogleDriveBackupStatusText"
                                                       Foreground="{StaticResource MutedBrush}" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,9,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#313338" BorderBrush="#45474f" BorderThickness="1"
                                            CornerRadius="8" Padding="16" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="HOW TO CONNECT GOOGLE DRIVE" Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11" FontWeight="Bold"/>
                                            <TextBlock Text="1. Open Google Cloud Console and select your FluxChat Drive project."
                                                       TextWrapping="Wrap" Margin="0,12,0,0"/>
                                            <TextBlock Text="2. Open APIs &amp; Services, then Library, find Google Drive API, and enable it."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="3. Open Google Auth Platform. If it is not configured, click Get started."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="4. In Branding, fill the app name, support email, and developer contact email, then save."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="5. In Audience, use External for a normal Google account. While testing, add your Google account as a test user."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="6. In Data Access, add the Google Drive API scope: drive.file."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="7. In Clients, create an OAuth client. Application type must be Desktop app."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="8. Copy the Client ID, paste it into the field above, then click Connect Google Drive."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>
                                            <TextBlock Text="If Google Cloud says access is blocked, enable 2-step verification on your Google account and refresh the page after a few minutes."
                                                       Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                            <Border Background="#282a30" BorderBrush="#3f424b" BorderThickness="1"
                                                    CornerRadius="6" Padding="12" Margin="0,12,0,0">
                                                <TextBlock Text="Important: use only the Client ID. FluxChat does not need a client secret for the Desktop OAuth flow."
                                                           Foreground="{StaticResource SubtleBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#313338" BorderBrush="#45474f" BorderThickness="1"
                                            CornerRadius="8" Padding="16" Margin="0,14,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Reduced motion" FontWeight="SemiBold"/>
