                                    <Border Background="#313338" BorderBrush="#45474f" BorderThickness="1"
                                            CornerRadius="8" Padding="16" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="GOOGLE DRIVE" Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11" FontWeight="Bold"/>
                                            <TextBlock x:Name="GoogleDriveStatusText" Text="Not connected"
                                                       Margin="0,8,0,0" FontWeight="SemiBold"/>
