                    <Border Background="#090a0c" CornerRadius="10" ClipToBounds="True">
                        <Grid>
                            <MediaElement x:Name="VideoViewerPlayer"
                                          Source="{Binding VideoSource}"
                                          Tag="{Binding}"
                                          Stretch="Uniform"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          ScrubbingEnabled="True"
                                          MediaOpened="VideoViewerPlayer_OnMediaOpened"
                                          MediaEnded="VideoViewerPlayer_OnMediaEnded"
                                          MediaFailed="VideoViewerPlayer_OnMediaFailed"
                                          MouseLeftButtonUp="VideoMessagePlayer_OnMouseLeftButtonUp"/>

                            <Border VerticalAlignment="Bottom"
                                    Margin="14"
                                    Padding="12,9"
                                    CornerRadius="8"
                                    Background="#E51B1D22">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Tag="{Binding}" Width="32" Height="32" Padding="0"
                                            Style="{StaticResource GhostButton}"
                                            Click="VideoPlayPauseButton_OnClick">
                                        <Grid Width="18" Height="18">
                                            <Path Fill="#ffffff" Data="M8,5V19L19,12Z">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVideoPlaying}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                            <Path Fill="#ffffff" Data="M6,5H10V19H6M14,5H18V19H14">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVideoPlaying}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Grid>
                                    </Button>
                                    <TextBlock Grid.Column="1" Margin="8,0"
                                               Text="{Binding VideoPositionText}"
                                               Foreground="#ffffff" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Slider Grid.Column="2" Tag="{Binding}"
                                            Minimum="0" Maximum="{Binding VideoDurationSeconds}"
                                            Value="{Binding VideoPositionSeconds, Mode=OneWay}"
                                            VerticalAlignment="Center"
                                            PreviewMouseLeftButtonUp="VideoTimeline_OnPreviewMouseLeftButtonUp"/>
                                    <TextBlock Grid.Column="3" Margin="8,0"
                                               Text="{Binding VideoDurationText}"
                                               Foreground="#ffffff" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Slider Grid.Column="4" Tag="{Binding}"
                                            Minimum="0" Maximum="1"
                                            Value="{Binding VideoVolume}"
                                            VerticalAlignment="Center"
                                            ValueChanged="VideoVolume_OnValueChanged"
                                            ToolTip="Volume"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Panel.ZIndex="4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,22,0"
                        Padding="6"
                        CornerRadius="8"
                        Background="#F22B2D31"
                        BorderBrush="#50535c"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource VideoViewerToolbarButton}"
                                ToolTip="Delete downloaded video from this device"
                                IsEnabled="{Binding CanDeleteLocalVideo}"
                                Tag="{Binding}"
                                Click="VideoDeleteLocalButton_OnClick">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="{StaticResource TextBrush}" Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6Z"/>
                            </Viewbox>
                        </Button>
                        <Button Margin="4,0,0,0"
                                ToolTip="Delete video from Google Drive"
                                Tag="{Binding}"
                                Click="VideoDeleteDriveButton_OnClick">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource VideoViewerToolbarButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanDeleteDriveVideo}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="18" Height="18">
                                <Path Fill="#ff777f" Data="M7.71,3.5L1.15,15L4.58,21L11.15,9.5M9.73,3.5L16.3,15H9.44L6,21H19.7L23.15,15L16.58,3.5Z"/>
                            </Viewbox>
                        </Button>
                        <Button Margin="4,0,0,0"
                                Style="{StaticResource VideoViewerToolbarButton}"
                                ToolTip="Close"
                                Click="VideoViewerCloseButton_OnClick">
                            <Viewbox Width="18" Height="18">
                                <Path Fill="{StaticResource TextBrush}" Data="M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59L18.3,5.71Z"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="AvatarEditorOverlay"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Panel.ZIndex="20"
                Background="#B0000000">
            <Grid>
                <Border Width="520"
                        Background="#313338"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="350"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Width="34"
                                    Height="34"
                                    Content="x"
                                    Style="{StaticResource GhostButton}"
                                    Click="AvatarEditorCancelButton_OnClick"/>
                            <StackPanel>
                                <TextBlock x:Name="AvatarEditorTitle"
                                           Text="Edit Avatar"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Drag to position. Use zoom to fit the circle."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="2"
                                Background="#202225"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Grid x:Name="AvatarEditorStage"
                                  MouseLeftButtonDown="AvatarEditorStage_OnMouseLeftButtonDown"
                                  MouseMove="AvatarEditorStage_OnMouseMove"
                                  MouseLeftButtonUp="AvatarEditorStage_OnMouseLeftButtonUp">
                                <Image x:Name="AvatarEditorImage"
                                       Visibility="Collapsed"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       RenderTransformOrigin="0.5,0.5"/>
                                <MediaElement x:Name="AvatarEditorVideo"
                                              Visibility="Collapsed"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual"
                                              Stretch="UniformToFill"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              IsMuted="True"
                                              RenderTransformOrigin="0.5,0.5"/>
                                <Rectangle Fill="#66000000"
                                           IsHitTestVisible="False"/>
                                <Ellipse Width="344"
                                         Height="344"
                                         Stroke="#f2f3f5"
                                         StrokeThickness="4"
                                         Fill="Transparent"
                                         IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="-"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AvatarEditorZoomSlider"
                                    Grid.Column="2"
                                    Minimum="1"
                                    Maximum="3"
                                    Value="1"
                                    ValueChanged="AvatarEditorZoomSlider_OnValueChanged"/>
                            <TextBlock Grid.Column="4"
                                       Text="+"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="AvatarEditorVideoControls"
                              Grid.Row="6"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Start"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AvatarEditorVideoStartSlider"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="60"
                                    Value="0"
                                    ValueChanged="AvatarEditorVideoSlider_OnValueChanged"/>
                            <TextBlock Grid.Row="2"
                                       Text="Length"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AvatarEditorVideoDurationSlider"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Minimum="1"
                                    Maximum="10"
                                    Value="10"
                                    ValueChanged="AvatarEditorVideoSlider_OnValueChanged"/>
                        </Grid>

                        <DockPanel Grid.Row="8">
                            <Button Content="Reset"
                                    Style="{StaticResource StatusMenuButton}"
                                    Click="AvatarEditorResetButton_OnClick"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="Cancel"
                                        Width="96"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource GhostButton}"
                                        Click="AvatarEditorCancelButton_OnClick"/>
                                <Button Content="Apply"
                                        Width="96"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="AvatarEditorApplyButton_OnClick"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="FirstRunVpsOverlay"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Background="#B0000000">
            <Grid>
                <Border Width="360"
                        Background="#2b2d31"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                          BlurRadius="28"
                                          ShadowDepth="0"
                                          Opacity="0.45"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="VPS SERVER"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FirstRunServerAddressInput"
                                     MinHeight="38"
                                     ToolTip="host:port"/>
                            <Button Grid.Column="2"
                                    Content="Link"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="FirstRunLinkButton_OnClick"/>
                        </Grid>

                        <TextBox x:Name="FirstRunServerAccessKeyInput"
                                 Grid.Row="4"
                                 MinHeight="38"
                                 ToolTip="Invite code or saved token"/>

                        <Button Grid.Row="6"
                                Content="VPS help"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Stretch"
                                Click="VpsHelpButton_OnClick"/>

                        <Button Grid.Row="8"
                                Content="Later"
                                Style="{StaticResource StatusMenuButton}"
                                HorizontalAlignment="Center"
                                Click="FirstRunLaterButton_OnClick"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
