        <Border x:Name="ImageViewerOverlay"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Panel.ZIndex="30"
                Opacity="1"
                Background="#E6111215"
                MouseLeftButtonUp="ImageViewerOverlay_OnMouseLeftButtonUp">
            <Grid ClipToBounds="True">
                <Grid.Resources>
                    <Style x:Key="ImageViewerToolbarButton" TargetType="{x:Type Button}">
                        <Setter Property="Width" Value="40"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="#3b3e46"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="ToolbarButtonBorder"
                                            Width="{TemplateBinding Width}"
                                            Height="{TemplateBinding Height}"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <Grid Width="22" Height="22"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToolbarButtonBorder" Property="Background" Value="#4a4d57"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="ToolbarButtonBorder" Property="Background" Value="#5865f2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>
                <ScrollViewer x:Name="ImageViewerScrollViewer"
                              Margin="24,76,24,24"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              PanningMode="Both"
                              Background="Transparent">
                    <Image x:Name="ImageViewerImage"
                           Stretch="Fill"
                           Cursor="None"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MouseEnter="ImageViewerImage_OnMouseEnter"
                           MouseMove="ImageViewerImage_OnMouseMove"
                           MouseLeave="ImageViewerImage_OnMouseLeave"
                           MouseLeftButtonUp="ImageViewerImage_OnMouseLeftButtonUp"/>
                </ScrollViewer>

