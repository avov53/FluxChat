<Window x:Class="FluxChat.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxChat"
        Width="1240"
        Height="780"
        MinWidth="980"
        MinHeight="640"
        Background="#1e1f22"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBrush" Color="#1e1f22"/>
        <SolidColorBrush x:Key="RailBrush" Color="#17181b"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#2b2d31"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#313338"/>
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#3a3c43"/>
        <SolidColorBrush x:Key="InputBrush" Color="#383a40"/>
        <SolidColorBrush x:Key="LineBrush" Color="#202225"/>
        <SolidColorBrush x:Key="TextBrush" Color="#f2f3f5"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#b5bac1"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#80848e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#5865f2"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#4752c4"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#23a55a"/>
        <SolidColorBrush x:Key="IdleBrush" Color="#f0b232"/>
        <SolidColorBrush x:Key="OfflineBrush" Color="#80848e"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3c45a5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#3a3c43"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusMenuButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#404249"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#45474f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#45474f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#111214"/>
            <Setter Property="BorderBrush" Value="#3f4148"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Opacity" Value="0"/>
            <EventSetter Event="Loaded" Handler="ContextMenu_OnLoaded"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#35373d"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#404249"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Height="58"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <Button DockPanel.Dock="Right"
                            Width="34"
                            Height="34"
                            Margin="10,0,0,0"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Settings"
                            VerticalAlignment="Center"
                            Click="SettingsButton_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#404249"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#4a4d55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SettingsGearIcon"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:0.45"
                                                         FillBehavior="Stop">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <Viewbox Width="18" Height="18">
                            <Path x:Name="SettingsGearIcon"
                                  Fill="#a3a7ae"
                                  Stretch="Uniform"
                                  RenderTransformOrigin="0.5,0.5"
                                  Data="M12,8.5A3.5,3.5 0 1,0 12,15.5A3.5,3.5 0 0,0 12,8.5M20.4,13.5C20.5,13 20.5,12.5 20.5,12C20.5,11.5 20.5,11 20.4,10.5L22.3,9C22.5,8.8 22.6,8.5 22.4,8.2L20.6,5.1C20.5,4.8 20.2,4.7 19.9,4.8L17.7,5.7C16.9,5.1 16.1,4.6 15.2,4.3L14.9,1.9C14.8,1.6 14.6,1.4 14.3,1.4H10.7C10.4,1.4 10.2,1.6 10.1,1.9L9.8,4.3C8.9,4.6 8.1,5.1 7.3,5.7L5.1,4.8C4.8,4.7 4.5,4.8 4.4,5.1L2.6,8.2C2.4,8.5 2.5,8.8 2.7,9L4.6,10.5C4.5,11 4.5,11.5 4.5,12C4.5,12.5 4.5,13 4.6,13.5L2.7,15C2.5,15.2 2.4,15.5 2.6,15.8L4.4,18.9C4.5,19.2 4.8,19.3 5.1,19.2L7.3,18.3C8.1,18.9 8.9,19.4 9.8,19.7L10.1,22.1C10.2,22.4 10.4,22.6 10.7,22.6H14.3C14.6,22.6 14.8,22.4 14.9,22.1L15.2,19.7C16.1,19.4 16.9,18.9 17.7,18.3L19.9,19.2C20.2,19.3 20.5,19.2 20.6,18.9L22.4,15.8C22.6,15.5 22.5,15.2 22.3,15L20.4,13.5Z">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Width="34"
                            Height="34"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Add friend"
                            VerticalAlignment="Center"
                            Click="AddFriendPanelButton_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#404249"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#4a4d55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="18" Height="18">
                            <Path Fill="#a3a7ae"
                                  Stretch="Uniform"
                                  Data="M10,11A4,4 0 1,0 10,3A4,4 0 0,0 10,11M10,13C6.7,13 4,14.6 4,16.6V18H12.5A5.8,5.8 0 0,1 12,15.6C12,14.7 12.2,13.8 12.6,13H10M17,12V15H20V17H17V20H15V17H12V15H15V12H17Z"/>
                        </Grid>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Width="34"
                            Height="34"
                            Margin="10,0,0,0"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Settings"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#404249"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#4a4d55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SettingsGear"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:0.45"
                                                         FillBehavior="Stop">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <TextBlock x:Name="SettingsGear"
                                   Text="⚙"
                                   FontSize="18"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FluxChat" FontSize="17" FontWeight="Bold"/>
                        <TextBlock x:Name="NetworkStatusText"
                                   Text="Connecting to VPS..."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="14,14,14,10" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="VPS SERVER"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="11"
                           FontWeight="Bold"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ServerAddressInput"
                             MinHeight="38"
                             ToolTip="host:port"/>
                    <Button Grid.Column="2"
                            Content="Link"
                            Style="{StaticResource PrimaryButton}"
                            Click="ConnectServerButton_OnClick"/>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="ServerAccessKeyInput"
                             MinHeight="38"
                             ToolTip="Invite code or saved token"/>
                    <Button Grid.Row="2"
                            Content="VPS help"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Stretch"
                            Click="VpsHelpButton_OnClick"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="10,12,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="4,0">
                    <TextBlock Text="DIRECT MESSAGES"
                               Foreground="{StaticResource SubtleBrush}"
                               FontSize="11"
                               FontWeight="Bold"/>
                    <Border DockPanel.Dock="Right"
                            Visibility="Collapsed"
                            Background="#3a3c43"
                            CornerRadius="4"
                            Padding="8,2">
                        <TextBlock x:Name="AddContactModeText"
                                   Text="User ID"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                    </Border>
                </DockPanel>

                <Grid Grid.Row="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ManualIpInput"
                             MinHeight="38"
                             ToolTip="Friend UserId or UserId@host:port"
                             Text=""/>

                    <Button Grid.Column="2"
                            Content="Add"
                            Height="38"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddContactButton_OnClick"/>
                </Grid>

                <Grid Grid.Row="4">
                    <TextBlock x:Name="EmptyContactsHint"
                               Text="Add another FluxChat user by UserId."
                               Foreground="{StaticResource SubtleBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Margin="26"/>

                    <ListBox x:Name="ContactsList"
                             MouseDoubleClick="ContactsList_OnMouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,7">
                                    <Grid.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Rename contact" Click="RenameContactMenuItem_OnClick"/>
                                            <MenuItem Header="Delete contact" Click="DeleteContactMenuItem_OnClick"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="42" Height="42">
                                        <Border CornerRadius="21" Background="#4e5058"/>
                                        <Grid>
                                            <Grid.Clip>
                                                <EllipseGeometry Center="21,21" RadiusX="21" RadiusY="21"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding AvatarImageSource}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvatarImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <MediaElement Source="{Binding AvatarPath}"
                                                          LoadedBehavior="Play"
                                                          UnloadedBehavior="Stop"
                                                          MediaEnded="AvatarVideo_OnMediaEnded"
                                                          Stretch="UniformToFill"
                                                          IsMuted="True">
                                                <MediaElement.Style>
                                                    <Style TargetType="MediaElement">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvatarVideo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MediaElement.Style>
                                            </MediaElement>
                                        </Grid>
                                        <TextBlock Text="{Binding Initials}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Ellipse Width="12"
                                                 Height="12"
                                                 Fill="{Binding StatusColor}"
                                                 Stroke="{StaticResource SidebarBrush}"
                                                 StrokeThickness="3"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"/>
                                    </Grid>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <DockPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding LastSeenText}"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding IpAddress}"
                                                   Foreground="{StaticResource SubtleBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="10,0,10,12">
                <Border x:Name="ProfileFlyout"
                        Visibility="Collapsed"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,72"
                        Background="#E62F3138"
                        BorderBrush="#5c5f68"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="ProfileFlyoutName"
                                   Text="Loading"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ProfileFlyoutUserId"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ProfileFlyoutAddress"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,10"
                                   TextTrimming="CharacterEllipsis"/>

                        <Border Height="1" Background="#45474f" Margin="0,0,0,8"/>

                        <Button Style="{StaticResource StatusMenuButton}"
                                Tag="Online"
                                Click="ProfileStatusButton_OnClick">
                            <DockPanel>
                                <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Online" FontWeight="SemiBold"/>
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource StatusMenuButton}"
                                Tag="Idle"
                                Margin="0,3,0,0"
                                Click="ProfileStatusButton_OnClick">
                            <DockPanel>
                                <Ellipse Width="10" Height="10" Fill="{StaticResource IdleBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Idle" FontWeight="SemiBold"/>
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource StatusMenuButton}"
                                Tag="Offline"
                                Margin="0,3,0,0"
                                Click="ProfileStatusButton_OnClick">
                            <DockPanel>
                                <Ellipse Width="10" Height="10" Fill="{StaticResource OfflineBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Offline" FontWeight="SemiBold"/>
                            </DockPanel>
                        </Button>

                        <Button Content="Copy User ID"
                                Margin="0,10,0,0"
                                Style="{StaticResource GhostButton}"
                                Click="CopyUserIdButton_OnClick"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ProfilePanel"
                        VerticalAlignment="Bottom"
                        Background="#CC2F3138"
                        BorderBrush="#4b4e57"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        MouseLeftButtonUp="ProfilePanel_OnMouseLeftButtonUp">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                          BlurRadius="18"
                                          ShadowDepth="0"
                                          Opacity="0.28"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="50" Height="50">
                            <Grid Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.Clip>
                                    <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                                </Grid.Clip>
                                <Ellipse x:Name="ProfileAvatarColor" Fill="#5865f2"/>
                                <Image x:Name="ProfileAvatarImage"
                                       Visibility="Collapsed"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       RenderTransformOrigin="0.5,0.5"/>
                                <MediaElement x:Name="ProfileAvatarVideo"
                                              Visibility="Collapsed"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual"
                                              Stretch="UniformToFill"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              IsMuted="True"
                                              RenderTransformOrigin="0.5,0.5"/>
                            </Grid>
                            <Ellipse x:Name="ProfileStatusRing"
                                     Stroke="{StaticResource SuccessBrush}"
                                     StrokeThickness="3"
                                     Fill="Transparent"/>
                            <TextBlock x:Name="ProfileInitialsText"
                                       Text="ME"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="13"/>
                        </Grid>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock x:Name="DisplayNameText"
                                       Text="Loading"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis"/>
                            <DockPanel Margin="0,4,0,0">
                                <Ellipse x:Name="ProfileStatusDot"
                                         Width="8"
                                         Height="8"
                                         Fill="{StaticResource SuccessBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <TextBlock x:Name="ProfileStatusText"
                                           Text="Online"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                            <TextBlock x:Name="UserIdText"
                                       Visibility="Collapsed"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="AddressText"
                                       Visibility="Collapsed"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3"
                                   Text="^"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Background="{StaticResource PanelBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="#"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="ChatTitle"
                               Text="Choose a contact"
                               FontSize="17"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="ChatSubtitle"
                               Text="Double-click a contact to open conversation"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="3"
                        x:Name="StartCallButton"
                        Width="36"
                        Height="36"
                        Background="#363940"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Start call"
                        Visibility="Collapsed"
                        Click="StartCallButton_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#404249"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#4a4d55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Width="18" Height="18">
                        <Path Fill="#d6d9df"
                              Stretch="Uniform"
                              Data="M6.6,10.8C8,13.6 10.4,16 13.2,17.4L15.4,15.2C15.7,14.9 16.1,14.8 16.5,14.9C17.7,15.3 19,15.5 20.3,15.5C20.9,15.5 21.4,16 21.4,16.6V20.2C21.4,20.8 20.9,21.3 20.3,21.3C10.6,21.3 2.7,13.4 2.7,3.7C2.7,3.1 3.2,2.6 3.8,2.6H7.4C8,2.6 8.5,3.1 8.5,3.7C8.5,5 8.7,6.3 9.1,7.5C9.2,7.9 9.1,8.3 8.8,8.6L6.6,10.8Z"/>
                    </Viewbox>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource LineBrush}"/>

            <Grid Grid.Row="2" Margin="20,16,20,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="CallPanel"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Height="150"
                        MinHeight="112"
                        MaxHeight="260"
                        Margin="0,0,0,10"
                        Background="#25272d"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="CallTitleText"
                                       Text="Call"
                                       FontWeight="Bold"
                                       FontSize="15"/>
                            <TextBlock x:Name="CallStatusText"
                                       Text="Connecting..."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       Margin="0,4,0,14"/>
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="58" Height="58" Margin="0,0,14,0">
                                    <Border CornerRadius="29" Background="#5865f2"/>
                                    <TextBlock x:Name="CallSelfInitials"
                                               Text="ME"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Width="58" Height="58">
                                    <Border CornerRadius="29" Background="#4e5058"/>
                                    <TextBlock x:Name="CallPeerInitials"
                                               Text="FR"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=CallStatusText}" Value="Incoming call">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, ElementName=CallStatusText}" Value="Calling...">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Right">
                            <Button x:Name="AcceptCallButton"
                                    Width="44"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Content="✓"
                                    Style="{StaticResource GhostButton}"
                                    Click="AcceptCallButton_OnClick"/>
                            <Button x:Name="DeclineCallButton"
                                    Width="44"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Content="✕"
                                    Style="{StaticResource GhostButton}"
                                    Click="DeclineCallButton_OnClick"/>
                            <Button x:Name="EndCallButton"
                                    Width="44"
                                    Height="36"
                                    Content="☎"
                                    Style="{StaticResource GhostButton}"
                                    Click="EndCallButton_OnClick"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <GridSplitter x:Name="CallPanelSplitter"
                              Grid.Row="1"
                              Visibility="Collapsed"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              ResizeDirection="Rows"
                              Background="Transparent"/>

                <Border x:Name="AddFriendPanel"
                        Grid.RowSpan="3"
                        Visibility="Collapsed"
                        Panel.ZIndex="5"
                        Width="520"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,54,0,0"
                        Background="#2b2d31"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Add Friend"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Grid.Row="2"
                                   Text="Enter a User ID or UserId@host:port."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"/>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AddFriendInput"
                                     MinHeight="42"
                                     ToolTip="Friend UserId or UserId@host:port"/>
                            <Button Grid.Column="2"
                                    Content="Add"
                                    Height="42"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="AddContactButton_OnClick"/>
                        </Grid>

                        <TextBlock Grid.Row="6"
                                   Text="Incoming friend requests"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"/>

                        <ListBox x:Name="FriendRequestsList"
                                 Grid.Row="8"
                                 MaxHeight="170">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="38" Height="38">
                                            <Border CornerRadius="19" Background="#4e5058"/>
                                            <Grid>
                                                <Grid.Clip>
                                                    <EllipseGeometry Center="19,19" RadiusX="19" RadiusY="19"/>
                                                </Grid.Clip>
                                                <Image Source="{Binding AvatarImageSource}"
                                                       Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAvatarImage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <MediaElement Source="{Binding AvatarPath}"
                                                              LoadedBehavior="Play"
                                                              UnloadedBehavior="Stop"
                                                              MediaEnded="AvatarVideo_OnMediaEnded"
                                                              Stretch="UniformToFill"
                                                              IsMuted="True">
                                                    <MediaElement.Style>
                                                        <Style TargetType="MediaElement">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAvatarVideo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MediaElement.Style>
                                                </MediaElement>
                                            </Grid>
                                            <TextBlock Text="{Binding Initials}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding UserId}"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Content="Accept"
                                                Height="32"
                                                Style="{StaticResource GhostButton}"
                                                Click="AcceptFriendRequestButton_OnClick"/>
                                        <Button Grid.Column="5"
                                                Content="Decline"
                                                Height="32"
                                                Style="{StaticResource GhostButton}"
                                                Click="DeclineFriendRequestButton_OnClick"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <StackPanel x:Name="EmptyChatHint"
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Width="76" Height="76" CornerRadius="38" Background="#404249">
                        <TextBlock Text="#"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SubtleBrush}"/>
                    </Border>
                    <TextBlock Text="No conversation selected"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,18,0,0"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Pick a contact from Direct Messages."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="14"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ListBox x:Name="MessagesList"
                         Grid.Row="2">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border HorizontalAlignment="{Binding Side}"
                                    MaxWidth="620"
                                    CornerRadius="8"
                                    Padding="14,10"
                                    Margin="0,2,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#2b2d31"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                                <Setter Property="Background" Value="#3f4676"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding Body}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Foreground="{StaticResource TextBrush}"
                                               LineHeight="21"/>
                                    <TextBlock Text="{Binding TimeText}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Right"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border x:Name="ComposerPanel"
                    Grid.Row="3"
                    Visibility="Collapsed"
                    Padding="20,10,20,22"
                    Background="{StaticResource PanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageInput"
                             MinHeight="46"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             KeyDown="MessageInput_OnKeyDown"/>

                    <Button Grid.Column="2"
                            x:Name="SendButton"
                            Content="Send"
                            Height="46"
                            Style="{StaticResource PrimaryButton}"
                            Click="SendButton_OnClick"/>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="SettingsOverlay"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Background="#B0000000">
            <Grid>
                <Border Width="760"
                        Height="680"
                        Background="#2b2d31"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Background="#24262b">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Settings"
                                       Margin="18,18,18,14"
                                       FontSize="18"
                                       FontWeight="Bold"/>

                            <StackPanel Grid.Row="1" Margin="10,0">
                                <Button Style="{StaticResource StatusMenuButton}"
                                        Background="#404249"
                                        HorizontalContentAlignment="Left">
                                    <DockPanel>
                                        <Ellipse Width="9"
                                                 Height="9"
                                                 Fill="{StaticResource AccentBrush}"
                                                 Margin="0,0,10,0"/>
                                        <TextBlock Text="Account" FontWeight="SemiBold"/>
                                    </DockPanel>
                                </Button>
                            </StackPanel>

                            <Button Grid.Row="2"
                                    Content="Close"
                                    Margin="10,0,10,14"
                                    Style="{StaticResource GhostButton}"
                                    Click="SettingsCloseButton_OnClick"/>
                        </Grid>

                        <Border Grid.Column="1" Background="{StaticResource LineBrush}"/>

                        <Grid Grid.Column="2" Margin="24,20,24,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Width="34"
                                        Height="34"
                                        Content="x"
                                        Style="{StaticResource GhostButton}"
                                        Click="SettingsCloseButton_OnClick"/>
                                <StackPanel>
                                    <TextBlock Text="Account"
                                               FontSize="22"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Your profile and VPS relay connection."
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="13"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <StackPanel Grid.Row="2">
                                <Border Background="#313338"
                                        BorderBrush="#45474f"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="64" Height="64">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="32,32" RadiusX="32" RadiusY="32"/>
                                            </Grid.Clip>
                                            <Ellipse x:Name="SettingsAvatarPreview"
                                                     Fill="#5865f2"/>
                                            <Image x:Name="SettingsAvatarImage"
                                                   Visibility="Collapsed"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   RenderTransformOrigin="0.5,0.5"/>
                                            <MediaElement x:Name="SettingsAvatarVideo"
                                                          Visibility="Collapsed"
                                                          LoadedBehavior="Manual"
                                                          UnloadedBehavior="Manual"
                                                          Stretch="UniformToFill"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Stretch"
                                                          IsMuted="True"
                                                          RenderTransformOrigin="0.5,0.5"/>
                                            <TextBlock x:Name="SettingsAvatarInitials"
                                                       Text="ME"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="17"
                                                       FontWeight="Bold"/>
                                        </Grid>

                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="PROFILE"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11"
                                                       FontWeight="Bold"/>

                                            <TextBox x:Name="SettingsDisplayNameInput"
                                                     Grid.Row="2"
                                                     MinHeight="38"
                                                     ToolTip="Nickname"/>

                                            <StackPanel Grid.Row="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Image"
                                                            Height="28"
                                                            Margin="0,0,8,0"
                                                            Style="{StaticResource GhostButton}"
                                                            Click="ChooseAvatarImageButton_OnClick"/>
                                                    <Button Content="Video"
                                                            Height="28"
                                                            Margin="0,0,8,0"
                                                            Style="{StaticResource GhostButton}"
                                                            Click="ChooseAvatarVideoButton_OnClick"/>
                                                    <Button Content="Save profile"
                                                            Height="28"
                                                            Style="{StaticResource GhostButton}"
                                                            Click="SaveProfileButton_OnClick"/>
                                                </StackPanel>
                                                <Grid x:Name="InlineAvatarCropPanel"
                                                      Visibility="Collapsed"
                                                      Margin="0,12,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="6"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="6"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="6"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="6"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="82"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Zoom" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                                    <Slider x:Name="SettingsAvatarZoomSlider" Grid.Column="1" Minimum="1" Maximum="3" Value="1" ValueChanged="AvatarCropSlider_OnValueChanged"/>
                                                    <TextBlock Grid.Row="2" Text="Horizontal" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                                    <Slider x:Name="SettingsAvatarOffsetXSlider" Grid.Row="2" Grid.Column="1" Minimum="-180" Maximum="180" Value="0" ValueChanged="AvatarCropSlider_OnValueChanged"/>
                                                    <TextBlock Grid.Row="4" Text="Vertical" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                                    <Slider x:Name="SettingsAvatarOffsetYSlider" Grid.Row="4" Grid.Column="1" Minimum="-180" Maximum="180" Value="0" ValueChanged="AvatarCropSlider_OnValueChanged"/>
                                                    <TextBlock Grid.Row="6" Text="Start" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                                    <Slider x:Name="SettingsAvatarVideoStartSlider" Grid.Row="6" Grid.Column="1" Minimum="0" Maximum="60" Value="0" ValueChanged="AvatarVideoSlider_OnValueChanged"/>
                                                    <TextBlock Grid.Row="8" Text="Length" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                                    <Slider x:Name="SettingsAvatarVideoDurationSlider" Grid.Row="8" Grid.Column="1" Minimum="1" Maximum="10" Value="10" ValueChanged="AvatarVideoSlider_OnValueChanged"/>
                                                </Grid>
                                                <TextBlock x:Name="SettingsAvatarVideoHint"
                                                           Text="Animated avatars loop up to 10 seconds."
                                                           Foreground="{StaticResource SubtleBrush}"
                                                           FontSize="11"
                                                           Margin="0,8,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <Button Width="28" Height="28" Margin="0,0,8,0" Tag="#5865f2" Click="AvatarColorButton_OnClick">
                                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="#5865f2" CornerRadius="14"/></ControlTemplate></Button.Template>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,8,0" Tag="#23a55a" Click="AvatarColorButton_OnClick">
                                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="#23a55a" CornerRadius="14"/></ControlTemplate></Button.Template>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,8,0" Tag="#f0b232" Click="AvatarColorButton_OnClick">
                                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="#f0b232" CornerRadius="14"/></ControlTemplate></Button.Template>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,8,0" Tag="#eb459e" Click="AvatarColorButton_OnClick">
                                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="#eb459e" CornerRadius="14"/></ControlTemplate></Button.Template>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,8,0" Tag="#ed4245" Click="AvatarColorButton_OnClick">
                                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="#ed4245" CornerRadius="14"/></ControlTemplate></Button.Template>
                                                </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Background="#313338"
                                        BorderBrush="#45474f"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,14,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="VPS SERVER"
                                                   Foreground="{StaticResource SubtleBrush}"
                                                   FontSize="11"
                                                   FontWeight="Bold"/>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="SettingsServerAddressInput"
                                                     MinHeight="38"
                                                     ToolTip="host:port"/>
                                            <Button Grid.Column="2"
                                                    Content="Link"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="ConnectServerButton_OnClick"/>
                                        </Grid>

                                        <TextBox x:Name="SettingsServerAccessKeyInput"
                                                 Grid.Row="4"
                                                 MinHeight="38"
                                                 ToolTip="Invite code or saved token"/>

                                        <Button Grid.Row="6"
                                                Content="VPS help"
                                                Style="{StaticResource GhostButton}"
                                                HorizontalAlignment="Stretch"
                                                Click="VpsHelpButton_OnClick"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="AvatarEditorOverlay"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Panel.ZIndex="20"
                Background="#B0000000">
            <Grid>
                <Border Width="520"
                        Background="#313338"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="350"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Width="34"
                                    Height="34"
                                    Content="x"
                                    Style="{StaticResource GhostButton}"
                                    Click="AvatarEditorCancelButton_OnClick"/>
                            <StackPanel>
                                <TextBlock x:Name="AvatarEditorTitle"
                                           Text="Edit Avatar"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Drag to position. Use zoom to fit the circle."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="2"
                                Background="#202225"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Grid x:Name="AvatarEditorStage"
                                  MouseLeftButtonDown="AvatarEditorStage_OnMouseLeftButtonDown"
                                  MouseMove="AvatarEditorStage_OnMouseMove"
                                  MouseLeftButtonUp="AvatarEditorStage_OnMouseLeftButtonUp">
                                <Image x:Name="AvatarEditorImage"
                                       Visibility="Collapsed"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       RenderTransformOrigin="0.5,0.5"/>
                                <MediaElement x:Name="AvatarEditorVideo"
                                              Visibility="Collapsed"
                                              LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual"
                                              Stretch="UniformToFill"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              IsMuted="True"
                                              RenderTransformOrigin="0.5,0.5"/>
                                <Rectangle Fill="#66000000"
                                           IsHitTestVisible="False"/>
                                <Ellipse Width="344"
                                         Height="344"
                                         Stroke="#f2f3f5"
                                         StrokeThickness="4"
                                         Fill="Transparent"
                                         IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="-"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AvatarEditorZoomSlider"
                                    Grid.Column="2"
                                    Minimum="1"
                                    Maximum="3"
                                    Value="1"
                                    ValueChanged="AvatarEditorZoomSlider_OnValueChanged"/>
                            <TextBlock Grid.Column="4"
                                       Text="+"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="AvatarEditorVideoControls"
                              Grid.Row="6"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Start"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AvatarEditorVideoStartSlider"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="60"
                                    Value="0"
                                    ValueChanged="AvatarEditorVideoSlider_OnValueChanged"/>
                            <TextBlock Grid.Row="2"
                                       Text="Length"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="AvatarEditorVideoDurationSlider"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Minimum="1"
                                    Maximum="10"
                                    Value="10"
                                    ValueChanged="AvatarEditorVideoSlider_OnValueChanged"/>
                        </Grid>

                        <DockPanel Grid.Row="8">
                            <Button Content="Reset"
                                    Style="{StaticResource StatusMenuButton}"
                                    Click="AvatarEditorResetButton_OnClick"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="Cancel"
                                        Width="96"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource GhostButton}"
                                        Click="AvatarEditorCancelButton_OnClick"/>
                                <Button Content="Apply"
                                        Width="96"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="AvatarEditorApplyButton_OnClick"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="FirstRunVpsOverlay"
                Grid.ColumnSpan="2"
                Visibility="Collapsed"
                Background="#B0000000">
            <Grid>
                <Border Width="360"
                        Background="#2b2d31"
                        BorderBrush="#45474f"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                          BlurRadius="28"
                                          ShadowDepth="0"
                                          Opacity="0.45"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="VPS SERVER"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FirstRunServerAddressInput"
                                     MinHeight="38"
                                     ToolTip="host:port"/>
                            <Button Grid.Column="2"
                                    Content="Link"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="FirstRunLinkButton_OnClick"/>
                        </Grid>

                        <TextBox x:Name="FirstRunServerAccessKeyInput"
                                 Grid.Row="4"
                                 MinHeight="38"
                                 ToolTip="Invite code or saved token"/>

                        <Button Grid.Row="6"
                                Content="VPS help"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Stretch"
                                Click="VpsHelpButton_OnClick"/>

                        <Button Grid.Row="8"
                                Content="Later"
                                Style="{StaticResource StatusMenuButton}"
                                HorizontalAlignment="Center"
                                Click="FirstRunLaterButton_OnClick"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
