                                    </StackPanel>
                                </Border>

                                <StackPanel x:Name="MessageHoverActions"
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,-14,8,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanShowMessageActions}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Content="↪" Width="28" Height="28" Padding="0" Style="{StaticResource GhostButton}" ToolTip="Forward" Click="MessageForwardMenuItem_OnClick"/>
                                    <Button Content="↩" Width="28" Height="28" Padding="0" Margin="4,0,0,0" Style="{StaticResource GhostButton}" ToolTip="Reply" Click="MessageReplyMenuItem_OnClick"/>
                                    <Button Content="✎" Width="28" Height="28" Padding="0" Margin="4,0,0,0" ToolTip="Edit" Click="MessageEditMenuItem_OnClick">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEdit}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="MessageContainer" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="MessageHoverActions" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="GroupMembersPanel"
                        Grid.Row="2"
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Visibility="Collapsed"
                        Margin="0,0,0,8"
                        Background="#F02B2D31"
                        BorderBrush="#4b4e57"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock Text="Members"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Width="30"
                                    Height="30"
                                    Background="#363940"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Close"
                                    Click="GroupMembersCloseButton_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#484b54"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#5865f2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Path Stroke="#f2f3f5"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M0,0 L10,10 M10,0 L0,10"
                                      Width="10"
                                      Height="10"/>
                            </Button>
                        </DockPanel>

                        <ListBox x:Name="GroupMembersList"
                                 Grid.Row="2"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ChatScrollBarStyle}"/>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,5"
                                          Background="Transparent">
                                        <Grid.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Add friend" Click="GroupMemberAddFriendMenuItem_OnClick">
                                                    <MenuItem.Icon>
                                                        <Viewbox Width="17" Height="17">
                                                            <Path Style="{StaticResource ContextMenuIconPath}"
                                                                  Data="M15,14C12.33,14 7,15.33 7,18V20H23V18C23,15.33 17.67,14 15,14M6,10V7H4V10H1V12H4V15H6V12H9V10H6M15,12A4,4 0 1,0 15,4A4,4 0 0,0 15,12Z"/>
                                                        </Viewbox>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanAddFriend}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Rename contact" Click="GroupMemberRenameContactMenuItem_OnClick">
                                                    <MenuItem.Icon>
                                                        <Viewbox Width="17" Height="17">
                                                            <Path Style="{StaticResource ContextMenuIconPath}"
                                                                  Data="M3,17.25V21H6.75L17.8,9.95L14.05,6.2L3,17.25M20.7,7.05C21.1,6.65 21.1,6 20.7,5.6L18.4,3.3C18,2.9 17.35,2.9 16.95,3.3L15.15,5.1L18.9,8.85L20.7,7.05Z"/>
                                                        </Viewbox>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanRenameContact}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Write message" Click="GroupMemberWriteMessageMenuItem_OnClick">
                                                    <MenuItem.Icon>
                                                        <Viewbox Width="17" Height="17">
                                                            <Path Style="{StaticResource ContextMenuIconPath}"
                                                                  Data="M20,2H4A2,2 0 0,0 2,4V22L6,18H20A2,2 0 0,0 22,16V4A2,2 0 0,0 20,2Z"/>
                                                        </Viewbox>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanWriteMessage}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Make group owner" Click="GroupMemberMakeOwnerMenuItem_OnClick">
                                                    <MenuItem.Icon>
                                                        <Viewbox Width="17" Height="17">
                                                            <Path Style="{StaticResource ContextMenuIconPath}"
                                                                  Data="M5,16L3,5L8.5,10L12,4L15.5,10L21,5L19,16H5M19,19H5V21H19V19Z"/>
                                                        </Viewbox>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanMakeOwner}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Remove from group" Click="GroupMemberRemoveMenuItem_OnClick">
                                                    <MenuItem.Icon>
                                                        <Viewbox Width="17" Height="17">
                                                            <Path Style="{StaticResource ContextMenuDangerIconPath}"
                                                                  Data="M12,5A3.5,3.5 0 1,0 12,12A3.5,3.5 0 0,0 12,5M12,14C8.13,14 5,15.79 5,18V19H14.53C14.19,18.41 14,17.73 14,17C14,15.9 14.45,14.9 15.17,14.17C14.23,14.06 13.16,14 12,14M18,14L20,16L22,14L23.5,15.5L21.5,17.5L23.5,19.5L22,21L20,19L18,21L16.5,19.5L18.5,17.5L16.5,15.5L18,14Z"/>
                                                        </Viewbox>
                                                    </MenuItem.Icon>
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanRemoveFromGroup}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Grid.ContextMenu>

                                        <Border CornerRadius="8"
                                                Padding="8"
                                                Background="#25272d">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Width="42" Height="42">
                                                    <Border CornerRadius="21" Background="#4e5058"/>
                                                    <Grid>
                                                        <Grid.Clip>
                                                            <EllipseGeometry Center="21,21" RadiusX="21" RadiusY="21"/>
                                                        </Grid.Clip>
                                                        <Image Source="{Binding AvatarImageSource}" Stretch="UniformToFill">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvatarImage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                        <MediaElement Source="{Binding AvatarPath}"
                                                                      LoadedBehavior="Manual"
                                                                      UnloadedBehavior="Stop"
                                                                      Loaded="AvatarVideo_OnLoaded"
                                                                      MediaEnded="AvatarVideo_OnMediaEnded"
                                                                      Stretch="UniformToFill"
                                                                      IsMuted="True">
                                                            <MediaElement.Style>
                                                                <Style TargetType="MediaElement">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAvatarVideo}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </MediaElement.Style>
                                                        </MediaElement>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Initials}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ShortId}"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"/>
                                                    <DockPanel Margin="0,4,0,0">
                                                        <Ellipse Width="8"
                                                                 Height="8"
                                                                 Fill="{Binding StatusColor}"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                </StackPanel>

                                                <TextBlock Grid.Column="3"
                                                           Text="♛"
                                                           FontSize="18"
                                                           Foreground="#f6c65b"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOwner}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="ComposerPanel"
                    Grid.Row="3"
                    Visibility="Collapsed"
                    Padding="20,10,20,22"
                    Background="{StaticResource PanelBrush}"
                    AllowDrop="True"
                    PreviewDragOver="ComposerPanel_OnPreviewDragOver"
                    Drop="ComposerPanel_OnDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="ReplyEditBar"
                            Visibility="Collapsed"
                            Background="#25272d"
                            BorderBrush="#45474f"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="10,7"
                            Margin="0,0,0,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="x"
                                    Width="28"
                                    Height="26"
                                    Padding="0"
                                    Style="{StaticResource GhostButton}"
                                    Click="ClearReplyEditButton_OnClick"/>
                            <StackPanel>
                                <TextBlock x:Name="ReplyEditTitleText"
                                           Text="Replying"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                                <TextBlock x:Name="ReplyEditPreviewText"
                                           Text=""
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border x:Name="ImageDraftBar"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Background="#25272d"
                            BorderBrush="#45474f"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,0,0,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="x"
                                    Width="28"
                                    Height="26"
                                    Padding="0"
                                    Style="{StaticResource GhostButton}"
                                    Click="ClearImageDraftButton_OnClick"/>
                            <Image x:Name="ImageDraftPreview"
                                   Width="132"
                                   Height="82"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left"/>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Image ready to send"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                                <TextBlock Text="Type a caption below, then press Send"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border x:Name="FileDraftBar"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Background="#25272d"
                            BorderBrush="#45474f"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="44" Height="44" CornerRadius="7" Background="#343956">
                                <Path Width="22" Height="22" Stretch="Uniform" Fill="#c8ceff"
                                      Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8M14,2V8H20M8,13H16M8,17H14"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="FileDraftNameText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="FileDraftStatusText" Text="Ready to upload to Google Drive"
                                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,3,0,0"/>
                                <ProgressBar x:Name="FileDraftProgress" Height="4" Minimum="0" Maximum="100"
                                             Value="0" Visibility="Collapsed" Margin="0,7,12,0"/>
                            </StackPanel>
                            <Button Grid.Column="3" Content="x" Width="28" Height="28" Padding="0"
                                    Style="{StaticResource GhostButton}" ToolTip="Remove attachment"
                                    Click="ClearFileDraftButton_OnClick"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="EmojiOpenButton"
                                    Style="{StaticResource ComposerIconButton}"
                                    ToolTip="Emoji"
                                    Click="EmojiButton_OnClick">
                                <Grid Width="30"
                                      Height="30"
                                      IsHitTestVisible="False">
                                    <TextBlock x:Name="EmojiOpenButtonFallback"
                                               Text="☺"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="22"
                                               Foreground="{StaticResource TextBrush}"/>
                                    <Image x:Name="EmojiOpenButtonImage"
                                           Width="22"
                                           Height="22"
                                           Stretch="Uniform"
                                           Visibility="Collapsed"/>
                                </Grid>
                            </Button>
                            <Button Content="GIF"
                                    Margin="6,0,0,0"
                                    Width="48"
                                    Style="{StaticResource ComposerIconButton}"
                                    ToolTip="GIF"
                                    Click="GifButton_OnClick"/>
                            <Button Content="+"
                                    Margin="6,0,0,0"
                                    Style="{StaticResource ComposerIconButton}"
                                    ToolTip="Attach image or file"
                                    Click="AttachImageButton_OnClick"/>
                        </StackPanel>

                        <Grid Grid.Column="2"
                              MinHeight="46"
                              MaxHeight="120">
                            <ItemsControl x:Name="MessageInputEmojiPreview"
                                          Panel.ZIndex="1"
                                          Margin="13,10,13,9"
                                          IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Text}"
                                                       FontSize="{Binding Size}"
                                                       LineHeight="{Binding TextLineHeight}"
                                                       Foreground="{StaticResource TextBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsText}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Image Source="{Binding ImageUrl}"
                                                   Width="{Binding ImageSize}"
                                                   Height="{Binding ImageSize}"
                                                   Margin="1,0"
                                                   Stretch="Uniform">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmoji}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox x:Name="MessageInput"
                                     Panel.ZIndex="0"
                                     MinHeight="46"
                                     MaxHeight="120"
                                     AcceptsReturn="True"
                                     Foreground="Transparent"
                                     SelectionBrush="#6b76ff"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="MessageInput_OnTextChanged"
                                     KeyDown="MessageInput_OnKeyDown"
                                     PreviewKeyDown="MessageInput_OnPreviewKeyDown"
                                     PreviewTextInput="MessageInput_OnPreviewTextInput"/>
                        </Grid>

                        <Button Grid.Column="4"
                                x:Name="SendButton"
                                Content="Send"
                                Height="46"
                                Style="{StaticResource PrimaryButton}"
                                Click="SendButton_OnClick"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Canvas x:Name="PickerWorkspace"
                                Height="0"
                                Visibility="Visible"
                                ClipToBounds="True"
                                Background="Transparent"
                                SizeChanged="PickerWorkspace_OnSizeChanged"
                                Thumb.DragCompleted="PickerThumb_OnDragCompleted">
                            <Canvas.Resources>
                                <Style x:Key="PickerInteractionThumb" TargetType="{x:Type Thumb}">
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Canvas.Resources>
                            <Border x:Name="EmojiPanel"
                                    Canvas.Left="0"
                                    Canvas.Top="0"
                                    Visibility="Hidden"
                                    Width="420"
                                    Height="340"
                                    MinWidth="250"
                                    MinHeight="210"
                                    Background="#202225"
                                    BorderBrush="#4b4e57"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    ClipToBounds="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.34"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="#292b31" BorderBrush="#3f424a" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                            </Grid.ColumnDefinitions>
                                            <Thumb Style="{StaticResource PickerInteractionThumb}"
                                                   Tag="Emoji|Move"
                                                   Background="Transparent"
                                                   Cursor="SizeAll"
                                                   DragStarted="PickerThumb_OnDragStarted"
                                                   DragDelta="PickerThumb_OnDragDelta"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        IsHitTestVisible="False">
                                                <TextBlock Text="Emoji" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="  drag or resize" Foreground="{StaticResource SubtleBrush}" FontSize="11"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Tag="Emoji"
                                                    Content="x"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Style="{StaticResource GhostButton}"
                                                    ToolTip="Close emoji"
                                                    Click="PickerCloseButton_OnClick"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="1" Padding="8" ClipToBounds="True">
                                        <wv2:WebView2CompositionControl x:Name="EmojiWebView"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        DefaultBackgroundColor="Transparent"/>
                                    </Border>

