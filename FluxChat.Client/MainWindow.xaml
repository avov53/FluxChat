                                            <TextBox x:Name="GoogleDriveClientIdInput" MinHeight="36"
                                                     ToolTip="Google OAuth Desktop client ID (public identifier)"/>
                                            <TextBlock Text="OAuth client ID is needed for self-built public releases; no private client secret is stored in FluxChat."
                                                       Foreground="{StaticResource SubtleBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,10"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="GoogleDriveConnectButton" Content="Connect Google Drive"
                                                        Style="{StaticResource PrimaryButton}" Click="GoogleDriveConnectButton_OnClick"/>
                                                <Button x:Name="GoogleDriveDisconnectButton" Content="Disconnect"
                                                        Margin="8,0,0,0" Style="{StaticResource GhostButton}"
                                                        Visibility="Collapsed" Click="GoogleDriveDisconnectButton_OnClick"/>
