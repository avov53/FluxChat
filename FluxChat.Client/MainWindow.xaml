                          Width="28"
                          Height="28"
                          Visibility="Collapsed">
                        <Path Stroke="#cc000000"
                              StrokeThickness="5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M10,3.5A6.5,6.5 0 1 1 9.99,16.5A6.5,6.5 0 0 1 10,3.5M14.8,14.8L22,22"/>
                        <Path Stroke="#ffffff"
                              StrokeThickness="2.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M10,3.5A6.5,6.5 0 1 1 9.99,16.5A6.5,6.5 0 0 1 10,3.5M14.8,14.8L22,22"/>
                    </Grid>
                </Canvas>

                <Border x:Name="ImageViewerToolbar"
                        Panel.ZIndex="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,16,0,0"
                        Padding="6"
                        CornerRadius="8"
                        Background="#F22B2D31"
                        BorderBrush="#50535c"
                        BorderThickness="1">
