                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Width="34"
                            Height="34"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Add friend"
                            VerticalAlignment="Center"
                            Click="AddFriendPanelButton_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#404249"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#4a4d55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid Width="18" Height="18">
                            <Path Fill="#a3a7ae"
                                  Stretch="Uniform"
                                  Data="M10,11A4,4 0 1,0 10,3A4,4 0 0,0 10,11M10,13C6.7,13 4,14.6 4,16.6V18H12.5A5.8,5.8 0 0,1 12,15.6C12,14.7 12.2,13.8 12.6,13H10M17,12V15H20V17H17V20H15V17H12V15H15V12H17Z"/>
                        </Grid>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Width="34"
                            Height="34"
                            Margin="10,0,0,0"
                            Background="#363940"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Settings"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="17">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#404249"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#4a4d55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SettingsGear"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:0.45"
                                                         FillBehavior="Stop">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <TextBlock x:Name="SettingsGear"
                                   Text="⚙"
                                   FontSize="18"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FluxChat" FontSize="17" FontWeight="Bold"/>
                        <TextBlock x:Name="NetworkStatusText"
                                   Text="Connecting to VPS..."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="14,14,14,10" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="VPS SERVER"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="11"
                           FontWeight="Bold"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ServerAddressInput"
                             MinHeight="38"
                             ToolTip="host:port"/>
                    <Button Grid.Column="2"
                            Content="Link"
                            Style="{StaticResource PrimaryButton}"
                            Click="ConnectServerButton_OnClick"/>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="ServerAccessKeyInput"
                             MinHeight="38"
                             ToolTip="Invite code or saved token"/>
                    <Button Grid.Row="2"
                            Content="VPS help"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Stretch"
                            Click="VpsHelpButton_OnClick"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="10,12,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="4,0">
                    <TextBlock Text="DIRECT MESSAGES"
                               Foreground="{StaticResource SubtleBrush}"
                               FontSize="11"
                               FontWeight="Bold"/>
                    <Border DockPanel.Dock="Right"
                            Visibility="Collapsed"
                            Background="#3a3c43"
                            CornerRadius="4"
                            Padding="8,2">
                        <TextBlock x:Name="AddContactModeText"
                                   Text="User ID"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                    </Border>
                </DockPanel>

                <Grid Grid.Row="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ManualIpInput"
                             MinHeight="38"
                             ToolTip="Friend UserId or UserId@host:port"
                             Text=""/>

                    <Button Grid.Column="2"
                            Content="Add"
                            Height="38"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddContactButton_OnClick"/>
                </Grid>

                <Grid Grid.Row="4">
                    <TextBlock x:Name="EmptyContactsHint"
                               Text="Add another FluxChat user by UserId."
                               Foreground="{StaticResource SubtleBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Margin="26"/>

                    <ListBox x:Name="ContactsList"
                             SelectionChanged="ContactsList_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,7">
                                    <Grid.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Rename contact" Click="RenameContactMenuItem_OnClick">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="17" Height="17">
                                                        <Path Style="{StaticResource ContextMenuIconPath}"
                                                              Data="M3,17.25V21H6.75L17.8,9.95L14.05,6.2L3,17.25M20.7,7.05C21.1,6.65 21.1,6 20.7,5.6L18.4,3.3C18,2.9 17.35,2.9 16.95,3.3L15.15,5.1L18.9,8.85L20.7,7.05Z"/>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanRenameContact}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="Remove from friends" Click="DeleteContactMenuItem_OnClick">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="17" Height="17">
                                                        <Path Style="{StaticResource ContextMenuDangerIconPath}"
                                                              Data="M12,5A3.5,3.5 0 1,0 12,12A3.5,3.5 0 0,0 12,5M12,14C8.13,14 5,15.79 5,18V19H14.53C14.19,18.41 14,17.73 14,17C14,15.9 14.45,14.9 15.17,14.17C14.23,14.06 13.16,14 12,14M18,14L20,16L22,14L23.5,15.5L21.5,17.5L23.5,19.5L22,21L20,19L18,21L16.5,19.5L18.5,17.5L16.5,15.5L18,14Z"/>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanRemoveFromFriends}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="Edit group name" Click="EditGroupNameMenuItem_OnClick">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="17" Height="17">
                                                        <Path Style="{StaticResource ContextMenuIconPath}"
                                                              Data="M3,17.25V21H6.75L17.8,9.95L14.05,6.2L3,17.25M20.7,7.05C21.1,6.65 21.1,6 20.7,5.6L18.4,3.3C18,2.9 17.35,2.9 16.95,3.3L15.15,5.1L18.9,8.85L20.7,7.05Z"/>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanEditGroup}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="Edit group picture" Click="EditGroupPictureMenuItem_OnClick">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="17" Height="17">
                                                        <Path Style="{StaticResource ContextMenuIconPath}"
                                                              Data="M21,19V5C21,3.9 20.1,3 19,3H5C3.9,3 3,3.9 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19M8.5,11.5L11,14.5L14.5,10L19,16H5L8.5,11.5Z"/>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanEditGroup}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="Delete group" Click="DeleteGroupMenuItem_OnClick">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="17" Height="17">
                                                        <Path Style="{StaticResource ContextMenuDangerIconPath}"
                                                              Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z"/>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanEditGroup}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="Leave group" Click="LeaveGroupMenuItem_OnClick">
                                                <MenuItem.Icon>
                                                    <Viewbox Width="17" Height="17">
                                                        <Path Style="{StaticResource ContextMenuDangerIconPath}"
                                                              Data="M10,17V14H3V10H10V7L15,12L10,17M12,2H21A2,2 0 0,1 23,4V20A2,2 0 0,1 21,22H12A2,2 0 0,1 10,20V18H12V20H21V4H12V6H10V4A2,2 0 0,1 12,2Z"/>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanLeaveGroup}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="42" Height="42">
                                        <Border CornerRadius="21" Background="#4e5058"/>
                                        <Grid>
                                            <Grid.Clip>
                                                <EllipseGeometry Center="21,21" RadiusX="21" RadiusY="21"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding AvatarImageSource}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvatarImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <MediaElement Source="{Binding AvatarPath}"
                                                          LoadedBehavior="Manual"
                                                          UnloadedBehavior="Stop"
                                                          Loaded="AvatarVideo_OnLoaded"
                                                          MediaEnded="AvatarVideo_OnMediaEnded"
                                                          Stretch="UniformToFill"
                                                          IsMuted="True">
                                                <MediaElement.Style>
                                                    <Style TargetType="MediaElement">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvatarVideo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MediaElement.Style>
                                            </MediaElement>
                                        </Grid>
                                        <TextBlock Text="{Binding Initials}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Ellipse Width="12"
                                                 Height="12"
                                                 Fill="{Binding StatusColor}"
                                                 Stroke="{StaticResource SidebarBrush}"
                                                 StrokeThickness="3"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <DockPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding LastSeenText}"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="11"/>
                                        </DockPanel>
                                        <Grid Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding IpAddress}"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding GroupMemberCountText}"
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Image Grid.Column="1" Source="{Binding BadgeImageSource}" Width="18" Height="18"
                                                   Margin="8,0,0,0" Stretch="Uniform" ToolTip="{Binding BadgeToolTip}">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasVerifiedBadge}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="10,0,10,12">
                <Border x:Name="ProfileFlyout"
                        Visibility="Collapsed"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,72"
                        Background="#E62F3138"
                        BorderBrush="#5c5f68"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="ProfileFlyoutName"
                                   Text="Loading"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ProfileFlyoutUserId"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ProfileFlyoutAddress"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,10"
                                   TextTrimming="CharacterEllipsis"/>

                        <Border Height="1" Background="#45474f" Margin="0,0,0,8"/>

                        <Button Style="{StaticResource StatusMenuButton}"
                                Tag="Online"
